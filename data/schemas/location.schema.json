{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "location.schema.json",
  "title": "The Mind's Eye Location Records",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["location_id", "map_id", "label", "source_ids"],
    "additionalProperties": false,
    "properties": {
      "location_id": { "type": "string", "minLength": 1, "pattern": "^loc_[a-z0-9_]+$" },
      "map_id": { "type": "string", "minLength": 1, "pattern": "^map_[a-z0-9_]+$" },
      "label": { "type": "string", "minLength": 1 },
      "street": { "type": "string" },
      "location_type": { "type": "string", "minLength": 1 },
      "source_ids": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": { "type": "string", "minLength": 1, "pattern": "^source_[a-z0-9_]+$" }
      },
      "certainty": { "type": "string", "enum": ["verified", "inferred", "placeholder", "unknown"] },
      "notes": { "type": "string" }
    }
  }
}
