NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Server-only. Required for Historical Map Studio uploads, signed image URLs,
# layout persistence, metadata edits, replacement, deletion, and georeferencing saves.
# Never expose this as NEXT_PUBLIC_* and never commit real keys.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SANBORN_MAX_UPLOAD_BYTES=26214400

# Optional. Used by the server-side location search route when calling Nominatim.
GEOCODING_USER_AGENT=TheMindsEye/0.1 (https://github.com/drbellschool/TheMindsEye)
