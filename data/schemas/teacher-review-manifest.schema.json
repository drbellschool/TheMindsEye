{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "teacher-review-manifest.schema.json",
  "title": "The Mind's Eye Teacher Review Manifest",
  "type": "object",
  "required": [
    "teacher_review_manifest_id",
    "manifest_type",
    "town_package_id",
    "mission_id",
    "instructional_manifest_id",
    "title",
    "teacher_authority_rule",
    "review_status",
    "mission_release_status",
    "record_count",
    "review_items"
  ],
  "additionalProperties": false,
  "properties": {
    "teacher_review_manifest_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^teacher_review_[a-z0-9_]+$"
    },
    "manifest_type": {
      "type": "string",
      "const": "mission_teacher_review_manifest"
    },
    "town_package_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9_]+$"
    },
    "mission_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^mission_[a-z0-9_]+$"
    },
    "instructional_manifest_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^instructional_[a-z0-9_]+$"
    },
    "title": { "type": "string", "minLength": 1 },
    "teacher_authority_rule": { "type": "string", "minLength": 1 },
    "review_status": {
      "type": "string",
      "enum": ["pending_teacher_review", "approved", "rejected"]
    },
    "mission_release_status": {
      "type": "string",
      "enum": ["draft", "approved_for_classroom_use", "rejected"]
    },
    "record_count": { "type": "integer", "minimum": 1 },
    "review_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "review_item_id",
          "alignment_id",
          "framework",
          "decision_state",
          "teacher_review_required",
          "notes"
        ],
        "additionalProperties": false,
        "properties": {
          "review_item_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^teacher_review_[a-z0-9_]+$"
          },
          "alignment_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^alignment_[a-z0-9_]+$"
          },
          "framework": {
            "type": "string",
            "enum": ["HQIM", "TEKS"]
          },
          "decision_state": {
            "type": "string",
            "enum": ["pending_teacher_selection", "approved", "rejected"]
          },
          "standard_id": { "type": "string", "minLength": 1 },
          "teacher_review_required": { "type": "boolean", "const": true },
          "notes": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "framework": { "const": "TEKS" },
                "decision_state": { "const": "approved" }
              }
            },
            "then": {
              "required": ["standard_id"]
            }
          }
        ]
      }
    }
  }
}
