{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claim.schema.json",
  "title": "The Mind's Eye Claim Records",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["claim_id", "claim_text", "claim_type", "confidence", "source_ids", "reasoning_note"],
    "additionalProperties": false,
    "properties": {
      "claim_id": { "type": "string", "minLength": 1, "pattern": "^claim_[a-z0-9_]+$" },
      "claim_text": { "type": "string", "minLength": 1 },
      "claim_type": { "type": "string", "enum": ["verified_fact", "source_based_inference", "fictional_gameplay"] },
      "confidence": { "type": "string", "enum": ["high", "medium", "low", "placeholder", "fictional"] },
      "source_ids": {
        "type": "array",
        "uniqueItems": true,
        "items": { "type": "string", "minLength": 1, "pattern": "^source_[a-z0-9_]+$" }
      },
      "related_location_ids": {
        "type": "array",
        "uniqueItems": true,
        "items": { "type": "string", "minLength": 1, "pattern": "^loc_[a-z0-9_]+$" }
      },
      "related_entity_ids": {
        "type": "array",
        "uniqueItems": true,
        "items": { "type": "string", "minLength": 1 }
      },
      "reasoning_note": { "type": "string", "minLength": 1 },
      "student_visible": { "type": "boolean" },
      "teacher_visible": { "type": "boolean" }
    },
    "allOf": [
      {
        "if": {
          "required": ["claim_type"],
          "properties": {
            "claim_type": { "enum": ["verified_fact", "source_based_inference"] }
          }
        },
        "then": {
          "properties": {
            "source_ids": { "minItems": 1 },
            "confidence": { "not": { "const": "fictional" } }
          }
        }
      },
      {
        "if": {
          "required": ["claim_type"],
          "properties": {
            "claim_type": { "const": "fictional_gameplay" }
          }
        },
        "then": {
          "properties": {
            "confidence": { "const": "fictional" }
          }
        }
      }
    ]
  }
}
